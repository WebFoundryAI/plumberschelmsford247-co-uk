# Environment variables for local development
# This file is tracked in git - DO NOT add secrets here
# For production, configure environment variables in your hosting platform

# Google Maps Embed API key - set the actual key in your hosting platform (Netlify/Vercel)
# Get a key from: https://console.cloud.google.com (enable Maps Embed API)
GOOGLE_MAPS_API_KEY=AIzaSyB38UuKqjIJ1vG9iu8WKROgnJMqldKoYV8

# Ideal Postcodes API key for postcode lookup
# Sign up at https://ideal-postcodes.co.uk and set your key in Cloudflare Pages dashboard
# The 'iddqd' community key is for testing only (15 requests/day/IP limit)
IDEAL_POSTCODES_API_KEY=iddqd
