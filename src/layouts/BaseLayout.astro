---
import '../styles/global.css';
import { BRAND } from '../data/brand';
import { SERVICES } from '../data/services';
import { LOCATIONS } from '../data/locations';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = `https://${BRAND.domain}`;
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : Astro.url.href;
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={BRAND.brandName} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur border-b border-border">
    <!-- Top bar with phone -->
    <div class="bg-primary text-primary-foreground">
      <div class="container-wide flex items-center justify-between py-2 px-4">
        <div class="flex items-center gap-2 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <a href={`tel:${BRAND.phone}`} class="font-medium hover:underline">
            {BRAND.phoneFormatted}
          </a>
          {BRAND.emergencyAvailable && (
            <span class="ml-2 bg-accent text-accent-foreground px-2 py-0.5 rounded text-xs font-semibold">
              24/7 Emergency
            </span>
          )}
        </div>
        <span class="hidden sm:block text-sm">{BRAND.serviceAreaLabel}</span>
      </div>
    </div>

    <!-- Main navigation -->
    <div class="container-wide px-4">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2">
          <span class="text-xl font-bold text-primary">{BRAND.brandName}</span>
        </a>

        <!-- Desktop navigation -->
        <nav class="hidden lg:flex items-center gap-1">
          <a href="/" class="px-4 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors rounded-md hover:bg-muted">
            Home
          </a>
          <a href="/services" class="px-4 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors rounded-md hover:bg-muted">
            Services
          </a>
          <a href="/locations" class="px-4 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors rounded-md hover:bg-muted">
            Areas
          </a>
          <a href="/contact" class="ml-4 btn-primary">
            Get a Quote
          </a>
        </nav>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-button"
          class="lg:hidden p-3 -mr-3"
          aria-label="Toggle menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
        </button>
      </div>

      <!-- Mobile navigation -->
      <nav id="mobile-menu" class="lg:hidden py-4 border-t border-border hidden">
        <a href="/" class="block px-4 py-3 text-foreground hover:text-primary hover:bg-muted rounded-md transition-colors">
          Home
        </a>
        <a href="/services" class="block px-4 py-3 text-foreground hover:text-primary hover:bg-muted rounded-md transition-colors">
          Services
        </a>
        <a href="/locations" class="block px-4 py-3 text-foreground hover:text-primary hover:bg-muted rounded-md transition-colors">
          Areas
        </a>
        <div class="px-4 pt-4">
          <a href="/contact" class="block w-full btn-primary text-center">
            Get a Quote
          </a>
        </div>
      </nav>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-foreground text-background">
    <div class="container-wide px-4 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Brand column -->
        <div>
          <h3 class="text-xl font-bold mb-4">{BRAND.brandName}</h3>
          <p class="text-background/85 text-sm mb-4">{BRAND.tagline}</p>
          <div class="space-y-2 text-sm">
            <a href={`tel:${BRAND.phone}`} class="flex items-center gap-2 text-background/90 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              {BRAND.phoneFormatted}
            </a>
            <a href={`mailto:${BRAND.email}`} class="flex items-center gap-2 text-background/90 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
              {BRAND.email}
            </a>
            <div class="flex items-start gap-2 text-background/90">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span>
                {BRAND.addressLine1}, {BRAND.addressLine2}<br />
                {BRAND.postcode}
              </span>
            </div>
          </div>
        </div>

        <!-- Services column -->
        <div>
          <h4 class="font-semibold mb-4">Our Services</h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/services" class="text-background/85 hover:text-white transition-colors font-medium">
                All Services
              </a>
            </li>
            {SERVICES.map((service) => (
              <li>
                <a href={`/services/${service.slug}`} class="text-background/85 hover:text-white transition-colors">
                  {service.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Areas column -->
        <div>
          <h4 class="font-semibold mb-4">Areas We Cover</h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/locations" class="text-background/85 hover:text-white transition-colors font-medium">
                All Areas
              </a>
            </li>
            {LOCATIONS.slice(0, 6).map((location) => (
              <li>
                <a href={`/locations/${location.slug}`} class="text-background/85 hover:text-white transition-colors">
                  {location.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Quick links column -->
        <div>
          <h4 class="font-semibold mb-4">Quick Links</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="text-background/85 hover:text-white transition-colors">About Us</a></li>
            <li><a href="/faq" class="text-background/85 hover:text-white transition-colors">FAQs</a></li>
            <li><a href="/contact" class="text-background/85 hover:text-white transition-colors">Contact Us</a></li>
            <li><a href="/sitemap" class="text-background/85 hover:text-white transition-colors">Sitemap</a></li>
          </ul>

          <h4 class="font-semibold mb-3 mt-6">Legal</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/privacy" class="text-background/85 hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="/terms" class="text-background/85 hover:text-white transition-colors">Terms of Service</a></li>
            <li><a href="/cookies" class="text-background/85 hover:text-white transition-colors">Cookie Policy</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-background/20 mt-10 pt-6 text-center text-sm text-background/80">
        <p>
          &copy; {new Date().getFullYear()} {BRAND.brandName}. All rights reserved.
        </p>
      </div>
    </div>
  </footer>

  <!-- Mobile menu script -->
  <script>
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    menuButton?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
