---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BRAND } from '../data/brand';
import { PAGE_FAQS } from '../data/faqs';

const title = `FAQs | ${BRAND.brandName}`;
const description = `Common questions about drainage services in ${BRAND.serviceAreaLabel}. Find answers about blocked drains, costs, and emergency callouts.`;
---

<BaseLayout title={title} description={description} canonical="/faq">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4 text-center text-white">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Frequently Asked Questions</h1>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Answers to common questions about our drainage services
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="section-padding">
    <div class="container-wide px-4">
      <div class="max-w-3xl mx-auto">
        <div class="space-y-4">
          {PAGE_FAQS.map((faq) => (
            <details class="bg-card rounded-lg card-elevated group">
              <summary class="p-4 md:p-6 cursor-pointer font-semibold text-lg hover:text-primary transition-colors flex items-center justify-between">
                {faq.question}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 ml-2 group-open:rotate-180 transition-transform"><path d="m6 9 6 6 6-6"></path></svg>
              </summary>
              <div class="px-4 md:px-6 pb-4 md:pb-6 text-muted-foreground">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>

        <div class="mt-12 text-center">
          <h2 class="text-2xl font-bold mb-4">Still have questions?</h2>
          <p class="text-muted-foreground mb-6">
            Our friendly team is here to help with any drainage questions you may have.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`tel:${BRAND.phone}`} class="btn-primary">
              Call {BRAND.phoneFormatted}
            </a>
            <a href="/contact" class="btn-outline">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Need Drainage Help?</h2>
      <p class="text-xl text-primary-foreground/90 mb-8 max-w-2xl mx-auto">
        Our expert team is available 24/7 for emergency callouts across {BRAND.serviceAreaLabel}.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
