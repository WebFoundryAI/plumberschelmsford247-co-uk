---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BRAND } from '../data/brand';
import { ABOUT_CONTENT } from '../data/staticContent';

const title = `About Us | ${BRAND.brandName}`;
const description = `Learn about ${BRAND.brandName}, your trusted drainage specialists in ${BRAND.serviceAreaLabel}. Reliable, professional, and available 24/7.`;
---

<BaseLayout title={title} description={description} canonical="/about">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4 text-center text-white">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">About {BRAND.brandName}</h1>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Your trusted drainage specialists serving {BRAND.serviceAreaLabel}
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding">
    <div class="container-narrow px-4">
      <div class="prose prose-lg max-w-none">
        <h2 class="text-2xl font-bold mb-4">Trusted Drainage Specialists in {BRAND.serviceAreaLabel}</h2>
        {ABOUT_CONTENT.split('\n\n').map((paragraph) => (
          <p class="text-muted-foreground mb-6">{paragraph}</p>
        ))}
      </div>

      <div class="grid sm:grid-cols-3 gap-6 mt-12">
        <div class="text-center p-6 bg-muted/50 rounded-xl">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3 class="font-bold mb-2">Experienced Team</h3>
          <p class="text-sm text-muted-foreground">Fully trained and insured engineers</p>
        </div>
        <div class="text-center p-6 bg-muted/50 rounded-xl">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><circle cx="12" cy="12" r="10"></circle><polyline points="12,6 12,12 16,14"></polyline></svg>
          </div>
          <h3 class="font-bold mb-2">24/7 Available</h3>
          <p class="text-sm text-muted-foreground">Emergency service when you need it</p>
        </div>
        <div class="text-center p-6 bg-muted/50 rounded-xl">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3 class="font-bold mb-2">Fully Insured</h3>
          <p class="text-sm text-muted-foreground">Complete peace of mind guaranteed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-primary-foreground/90 mb-8 max-w-2xl mx-auto">
        Contact us today for a free, no-obligation quote.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
