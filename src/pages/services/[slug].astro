---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BRAND } from '../../data/brand';
import { SERVICES, getServiceBySlug } from '../../data/services';
import { LOCATIONS } from '../../data/locations';
import { getServiceFAQs } from '../../data/faqs';

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const service = getServiceBySlug(slug);

if (!service) {
  return Astro.redirect('/services');
}

const title = `${service.name} | ${BRAND.brandName}`;
const description = `${service.description} Available across ${BRAND.serviceAreaLabel}. Call ${BRAND.phoneFormatted} for fast response.`;

const otherServices = SERVICES.filter((s) => s.slug !== service.slug).slice(0, 3);
const topLocations = LOCATIONS.slice(0, 4);
const faqs = getServiceFAQs(service.slug);

const benefits = [
  "No call-out charges",
  "Fixed pricing with no hidden fees",
  "24/7 emergency availability",
  "Fully trained and insured engineers",
  "Latest equipment and techniques",
  "100% satisfaction guaranteed",
];
---

<BaseLayout title={title} description={description} canonical={`/services/${service.slug}`}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4">
        <a href="/services" class="inline-flex items-center gap-2 text-white/90 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          All Services
        </a>
        <div class="text-white">
          <span class="text-5xl mb-4 block">{service.icon}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">{service.name}</h1>
          <p class="text-lg text-white/90 max-w-2xl">
            Professional {service.name.toLowerCase()} services across {BRAND.serviceAreaLabel}. Fast response, no call-out fee.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding">
    <div class="container-wide px-4">
      <!-- Breadcrumbs -->
      <nav class="text-sm mb-6">
        <a href="/" class="text-primary hover:underline">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href="/services" class="text-primary hover:underline">Services</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-muted-foreground">{service.name}</span>
      </nav>

      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold mb-6">
            Professional {service.name} Services in {BRAND.serviceAreaLabel}
          </h2>

          <p class="text-muted-foreground mb-6 text-lg">
            {service.description}
          </p>

          <!-- Why Choose Us -->
          <h3 class="text-xl font-bold mt-10 mb-4">Why Choose Us?</h3>
          <ul class="space-y-3 mb-8">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-trust shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22,4 12,14.01 9,11.01"></polyline></svg>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>

          <!-- Sub-services -->
          {service.subServices && service.subServices.length > 0 && (
            <>
              <h3 class="text-xl font-bold mt-10 mb-4">{service.name} Services</h3>
              <div class="grid sm:grid-cols-2 gap-3 mb-8">
                {service.subServices.map((sub) => (
                  <a
                    href={`/services/${service.slug}/${sub.slug}`}
                    class="flex items-center gap-3 p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22,4 12,14.01 9,11.01"></polyline></svg>
                    <div>
                      <span class="font-medium block">{sub.name}</span>
                      <span class="text-sm text-muted-foreground">{sub.shortLabel || sub.description}</span>
                    </div>
                  </a>
                ))}
              </div>
            </>
          )}

          <!-- This service in key locations -->
          <h3 class="text-xl font-bold mt-8 mb-4">
            {service.name} in Your Area
          </h3>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {topLocations.map((loc) => (
              <a
                href={`/locations/${loc.slug}/${service.slug}`}
                class="flex items-center gap-2 p-3 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span class="font-medium">
                  {service.name} in {loc.name}
                </span>
              </a>
            ))}
          </div>

          <!-- FAQs -->
          <h3 class="text-xl font-bold mt-10 mb-4">
            Frequently Asked Questions About {service.name}
          </h3>
          <div class="space-y-3 mb-8">
            {faqs.map((faq) => (
              <details class="bg-muted rounded-lg">
                <summary class="p-4 cursor-pointer font-semibold hover:text-primary transition-colors">
                  {faq.question}
                </summary>
                <div class="px-4 pb-4 text-muted-foreground">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>

          <!-- Other Services -->
          <h3 class="text-xl font-bold mb-4">Other Services</h3>
          <div class="grid sm:grid-cols-3 gap-4">
            {otherServices.map((s) => (
              <a
                href={`/services/${s.slug}`}
                class="p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <span class="text-2xl block mb-2">{s.icon}</span>
                <span class="font-medium">{s.name}</span>
              </a>
            ))}
          </div>

          <!-- Internal links -->
          <div class="mt-8 pt-6 border-t border-border">
            <p class="text-sm text-muted-foreground">
              <a href="/" class="text-primary hover:underline">Home</a>
              {" · "}
              <a href="/services" class="text-primary hover:underline">All Services</a>
              {" · "}
              <a href="/locations" class="text-primary hover:underline">All Areas</a>
              {" · "}
              <a href="/contact" class="text-primary hover:underline">Contact Us</a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-card p-6 rounded-xl card-elevated sticky top-24">
            <h3 class="text-xl font-bold mb-4">Get a Quote</h3>
            <p class="text-muted-foreground mb-4">
              Contact us for a free, no-obligation quote for {service.name.toLowerCase()} services.
            </p>
            <a href={`tel:${BRAND.phone}`} class="btn-primary w-full text-center mb-3 block">
              Call {BRAND.phoneFormatted}
            </a>
            <a href="/contact" class="btn-outline w-full text-center block">
              Request a Callback
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">
        Need {service.name}?
      </h2>
      <p class="text-xl text-primary-foreground/90 mb-8 max-w-2xl mx-auto">
        Our expert team is ready to help. Call now for fast, professional service.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
