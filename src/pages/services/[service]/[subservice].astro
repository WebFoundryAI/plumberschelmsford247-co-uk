---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BRAND } from '../../../data/brand';
import { SERVICES, getServiceBySlug, getSubServiceBySlug } from '../../../data/services';
import { LOCATIONS } from '../../../data/locations';

export function getStaticPaths() {
  const paths = [];
  for (const service of SERVICES) {
    if (service.subServices) {
      for (const sub of service.subServices) {
        paths.push({
          params: { service: service.slug, subservice: sub.slug },
        });
      }
    }
  }
  return paths;
}

const { service: serviceSlug, subservice: subserviceSlug } = Astro.params;
const service = getServiceBySlug(serviceSlug);
const subService = getSubServiceBySlug(serviceSlug, subserviceSlug);

if (!service || !subService) {
  return Astro.redirect('/services');
}

const title = `${subService.name} | ${service.name} | ${BRAND.brandName}`;
const description = `${subService.description} Professional ${subService.name.toLowerCase()} services across ${BRAND.serviceAreaLabel}. Call ${BRAND.phoneFormatted}.`;

const topLocations = LOCATIONS.slice(0, 4);
const otherSubServices = service.subServices?.filter(s => s.slug !== subService.slug) || [];
---

<BaseLayout title={title} description={description} canonical={`/services/${service.slug}/${subService.slug}`}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4">
        <a href={`/services/${service.slug}`} class="inline-flex items-center gap-2 text-white/90 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          {service.name}
        </a>
        <div class="text-white">
          <span class="text-5xl mb-4 block">{service.icon}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">{subService.name}</h1>
          <p class="text-lg text-white/90 max-w-2xl">
            {subService.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding">
    <div class="container-wide px-4">
      <!-- Breadcrumbs -->
      <nav class="text-sm mb-6">
        <a href="/" class="text-primary hover:underline">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href="/services" class="text-primary hover:underline">Services</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href={`/services/${service.slug}`} class="text-primary hover:underline">{service.name}</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-muted-foreground">{subService.name}</span>
      </nav>

      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold mb-6">
            Professional {subService.name} Services in {BRAND.serviceAreaLabel}
          </h2>

          <div class="prose prose-lg max-w-none text-muted-foreground mb-8">
            <p>{subService.description}</p>
            <p>
              At {BRAND.brandName}, we provide fast, reliable {subService.name.toLowerCase()} services across {BRAND.serviceAreaLabel}.
              Our experienced team is available 24/7 for emergency callouts, and we never charge call-out fees.
            </p>
          </div>

          <!-- Why Choose Us -->
          <h3 class="text-xl font-bold mt-10 mb-4">Why Choose Us for {subService.name}?</h3>
          <ul class="space-y-3 mb-8">
            {[
              "Fast response - usually within 1-2 hours",
              "No call-out charges",
              "Fixed pricing with no hidden fees",
              "Fully trained and insured engineers",
              "100% satisfaction guaranteed",
            ].map((benefit) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-trust shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22,4 12,14.01 9,11.01"></polyline></svg>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>

          <!-- This service in key locations -->
          <h3 class="text-xl font-bold mt-8 mb-4">
            {subService.name} in Your Area
          </h3>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {topLocations.map((loc) => (
              <a
                href={`/locations/${loc.slug}/${service.slug}`}
                class="flex items-center gap-2 p-3 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span class="font-medium">
                  {service.name} in {loc.name}
                </span>
              </a>
            ))}
          </div>

          <!-- Other sub-services -->
          {otherSubServices.length > 0 && (
            <>
              <h3 class="text-xl font-bold mt-8 mb-4">Related {service.name} Services</h3>
              <div class="grid sm:grid-cols-2 gap-3 mb-8">
                {otherSubServices.map((sub) => (
                  <a
                    href={`/services/${service.slug}/${sub.slug}`}
                    class="p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
                  >
                    <span class="font-medium block">{sub.name}</span>
                    <span class="text-sm text-muted-foreground">{sub.shortLabel}</span>
                  </a>
                ))}
              </div>
            </>
          )}

          <!-- Internal links -->
          <div class="mt-8 pt-6 border-t border-border">
            <p class="text-sm text-muted-foreground">
              <a href="/" class="text-primary hover:underline">Home</a>
              {" · "}
              <a href="/services" class="text-primary hover:underline">All Services</a>
              {" · "}
              <a href={`/services/${service.slug}`} class="text-primary hover:underline">{service.name}</a>
              {" · "}
              <a href="/contact" class="text-primary hover:underline">Contact Us</a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-card p-6 rounded-xl card-elevated sticky top-24">
            <h3 class="text-xl font-bold mb-4">Get a Quote</h3>
            <p class="text-muted-foreground mb-4">
              Contact us for {subService.name.toLowerCase()} services.
            </p>
            <a href={`tel:${BRAND.phone}`} class="btn-primary w-full text-center mb-3 block">
              Call {BRAND.phoneFormatted}
            </a>
            <a href="/contact" class="btn-outline w-full text-center block">
              Request a Callback
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">
        Need {subService.name}?
      </h2>
      <p class="text-xl text-primary-foreground/90 mb-8">
        Call now for fast, professional service across {BRAND.serviceAreaLabel}.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
