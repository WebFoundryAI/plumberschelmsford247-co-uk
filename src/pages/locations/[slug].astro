---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BRAND } from '../../data/brand';
import { LOCATIONS, getLocationBySlug } from '../../data/locations';
import { SERVICES } from '../../data/services';
import { getLocationFAQs } from '../../data/faqs';
import { LOCATION_CONTENT } from '../../data/staticContent';

export function getStaticPaths() {
  return LOCATIONS.map((location) => ({
    params: { slug: location.slug },
  }));
}

const { slug } = Astro.params;
const location = getLocationBySlug(slug);

if (!location) {
  return Astro.redirect('/locations');
}

const title = `Drain Services in ${location.name} | ${BRAND.brandName}`;
const description = `Professional drainage services in ${location.name}, ${location.countyOrRegion}. 24/7 emergency drain unblocking, CCTV surveys, and repairs. Call ${BRAND.phoneFormatted}`;

const otherLocations = LOCATIONS.filter((l) => l.slug !== location.slug).slice(0, 4);
const faqs = getLocationFAQs(location.name);
const locationContent = LOCATION_CONTENT[location.slug] || `Need a reliable drainage specialist in ${location.name}? ${BRAND.brandName} provides fast, professional drainage services to homes and businesses throughout ${location.name} and the surrounding area.`;
---

<BaseLayout title={title} description={description} canonical={`/locations/${location.slug}`}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4">
        <a href="/locations" class="inline-flex items-center gap-2 text-white/90 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          All Areas
        </a>
        <div class="text-white">
          <div class="flex items-center gap-2 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span class="text-lg text-white/90">{location.countyOrRegion}</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            Drain Services in {location.name}
          </h1>
          <p class="text-lg text-white/90 max-w-2xl">
            Professional drain unblocking and repairs in {location.name}. 24/7 emergency service, no call-out fee.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding">
    <div class="container-wide px-4">
      <!-- Breadcrumbs -->
      <nav class="text-sm mb-6">
        <a href="/" class="text-primary hover:underline">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href="/locations" class="text-primary hover:underline">Areas</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-muted-foreground">{location.name}</span>
      </nav>

      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold mb-4">
            Expert Drainage Services in {location.name}
          </h2>

          <p class="text-muted-foreground mb-6 text-lg">
            {locationContent}
          </p>

          <!-- Services in this location -->
          <h3 class="text-xl font-bold mt-10 mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
            Our Services in {location.name}
          </h3>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {SERVICES.map((service) => (
              <a
                href={`/locations/${location.slug}/${service.slug}`}
                class="flex items-center gap-3 p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <span class="text-2xl">{service.icon}</span>
                <div>
                  <span class="font-medium block">{service.name}</span>
                  <span class="text-sm text-muted-foreground">{service.shortLabel}</span>
                </div>
              </a>
            ))}
          </div>

          <!-- FAQs -->
          <h3 class="text-xl font-bold mt-10 mb-4">
            Frequently Asked Questions About {location.name} Drainage
          </h3>
          <div class="space-y-3 mb-8">
            {faqs.map((faq) => (
              <details class="bg-muted rounded-lg">
                <summary class="p-4 cursor-pointer font-semibold hover:text-primary transition-colors">
                  {faq.question}
                </summary>
                <div class="px-4 pb-4 text-muted-foreground">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>

          <!-- Other locations -->
          <h3 class="text-xl font-bold mt-8 mb-4">Other Areas We Cover</h3>
          <div class="grid sm:grid-cols-2 gap-3">
            {otherLocations.map((l) => (
              <a
                href={`/locations/${l.slug}`}
                class="flex items-center gap-2 p-3 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span class="font-medium">{l.name}</span>
              </a>
            ))}
          </div>

          <!-- Internal links -->
          <div class="mt-8 pt-6 border-t border-border">
            <p class="text-sm text-muted-foreground">
              <a href="/" class="text-primary hover:underline">Home</a>
              {" · "}
              <a href="/services" class="text-primary hover:underline">All Services</a>
              {" · "}
              <a href="/locations" class="text-primary hover:underline">All Areas</a>
              {" · "}
              <a href="/contact" class="text-primary hover:underline">Contact Us</a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-card p-6 rounded-xl card-elevated sticky top-24">
            <h3 class="text-xl font-bold mb-4">
              Get a Quote in {location.name}
            </h3>
            <p class="text-muted-foreground mb-4">
              Contact us for drainage services in {location.name}.
            </p>
            <a href={`tel:${BRAND.phone}`} class="btn-primary w-full text-center mb-3 block">
              Call {BRAND.phoneFormatted}
            </a>
            <a href="/contact" class="btn-outline w-full text-center block">
              Request a Callback
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">
        Need Drainage Help in {location.name}?
      </h2>
      <p class="text-xl text-primary-foreground/90 mb-8">
        Our local team is ready to help. Call now for fast, professional service.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
