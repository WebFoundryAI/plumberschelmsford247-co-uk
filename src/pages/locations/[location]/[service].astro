---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BRAND } from '../../../data/brand';
import { LOCATIONS, getLocationBySlug } from '../../../data/locations';
import { SERVICES, getServiceBySlug } from '../../../data/services';

export function getStaticPaths() {
  const paths = [];
  for (const location of LOCATIONS) {
    for (const service of SERVICES) {
      paths.push({
        params: { location: location.slug, service: service.slug },
      });
    }
  }
  return paths;
}

const { location: locationSlug, service: serviceSlug } = Astro.params;
const location = getLocationBySlug(locationSlug);
const service = getServiceBySlug(serviceSlug);

if (!location || !service) {
  return Astro.redirect('/locations');
}

const title = `${service.name} in ${location.name} | ${BRAND.brandName}`;
const description = `Professional ${service.name.toLowerCase()} services in ${location.name}, ${location.countyOrRegion}. Fast response, fixed pricing. Call ${BRAND.phoneFormatted}`;

const otherServices = SERVICES.filter((s) => s.slug !== service.slug).slice(0, 3);
const nearbyLocations = LOCATIONS.filter((l) => l.slug !== location.slug).slice(0, 3);

const benefits = [
  `Local engineers covering ${location.name}`,
  "No call-out charges",
  "Fixed pricing with no hidden fees",
  "24/7 emergency availability",
  "Fully trained and insured",
];
---

<BaseLayout title={title} description={description} canonical={`/locations/${location.slug}/${service.slug}`}>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay py-16 md:py-20">
      <div class="container-wide px-4">
        <a href={`/locations/${location.slug}`} class="inline-flex items-center gap-2 text-white/90 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          Back to {location.name}
        </a>
        <div class="text-white">
          <span class="text-5xl mb-4 block">{service.icon}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            {service.name} in {location.name}
          </h1>
          <p class="text-lg text-white/90 max-w-2xl">
            Professional {service.name.toLowerCase()} services in {location.name}, {location.countyOrRegion}. Available 24/7.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-padding">
    <div class="container-wide px-4">
      <!-- Breadcrumbs -->
      <nav class="text-sm mb-6">
        <a href="/" class="text-primary hover:underline">Home</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href="/locations" class="text-primary hover:underline">Areas</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <a href={`/locations/${location.slug}`} class="text-primary hover:underline">{location.name}</a>
        <span class="mx-2 text-muted-foreground">/</span>
        <span class="text-muted-foreground">{service.name}</span>
      </nav>

      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold mb-4">
            Professional {service.name} Services in {location.name}
          </h2>

          <p class="text-muted-foreground mb-6 text-lg">
            Looking for {service.name.toLowerCase()} in {location.name}? {BRAND.brandName} provides fast, reliable {service.name.toLowerCase()} services to homes and businesses throughout {location.name} and the surrounding areas of {location.countyOrRegion}.
          </p>

          <p class="text-muted-foreground mb-6">
            {service.description}
          </p>

          <!-- Why Choose Us -->
          <h3 class="text-xl font-bold mt-8 mb-4">
            Why Choose {BRAND.brandName}?
          </h3>
          <ul class="space-y-3 mb-8">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-trust shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22,4 12,14.01 9,11.01"></polyline></svg>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>

          <!-- Sub-services in this service+location -->
          {service.subServices && service.subServices.length > 0 && (
            <>
              <h3 class="text-xl font-bold mb-4">
                {service.name} Services in {location.name}
              </h3>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
                {service.subServices.map((sub) => (
                  <a
                    href={`/services/${service.slug}/${sub.slug}`}
                    class="p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors group"
                  >
                    <span class="font-medium group-hover:text-primary transition-colors">
                      {sub.name}
                    </span>
                    <p class="text-sm text-muted-foreground mt-1">
                      {sub.shortLabel || sub.description}
                    </p>
                  </a>
                ))}
              </div>
            </>
          )}

          <!-- Other services in this location -->
          <h3 class="text-xl font-bold mb-4">
            Other Services in {location.name}
          </h3>
          <div class="grid sm:grid-cols-3 gap-4 mb-8">
            {otherServices.map((s) => (
              <a
                href={`/locations/${location.slug}/${s.slug}`}
                class="p-4 bg-muted rounded-lg hover:bg-muted/70 transition-colors group"
              >
                <span class="text-2xl block mb-2">{s.icon}</span>
                <span class="font-medium group-hover:text-primary transition-colors">
                  {s.name}
                </span>
                <p class="text-sm text-muted-foreground mt-1">
                  {s.shortLabel}
                </p>
              </a>
            ))}
          </div>

          <!-- Same service in nearby locations -->
          <h3 class="text-xl font-bold mb-4">
            {service.name} in Nearby Areas
          </h3>
          <div class="grid sm:grid-cols-3 gap-3 mb-8">
            {nearbyLocations.map((l) => (
              <a
                href={`/locations/${l.slug}/${service.slug}`}
                class="flex items-center gap-2 p-3 bg-muted rounded-lg hover:bg-muted/70 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span class="font-medium">{l.name}</span>
              </a>
            ))}
          </div>

          <!-- Internal links -->
          <div class="pt-6 border-t border-border">
            <p class="text-sm text-muted-foreground">
              <a href="/" class="text-primary hover:underline">Home</a>
              {" · "}
              <a href="/services" class="text-primary hover:underline">All Services</a>
              {" · "}
              <a href={`/services/${service.slug}`} class="text-primary hover:underline">{service.name}</a>
              {" · "}
              <a href={`/locations/${location.slug}`} class="text-primary hover:underline">{location.name}</a>
              {" · "}
              <a href="/contact" class="text-primary hover:underline">Contact Us</a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div>
          <div class="bg-card p-6 rounded-xl card-elevated sticky top-24">
            <h3 class="text-xl font-bold mb-4">
              Get a Quote in {location.name}
            </h3>
            <p class="text-muted-foreground mb-4">
              Contact us for {service.name.toLowerCase()} services in {location.name}.
            </p>
            <a href={`tel:${BRAND.phone}`} class="btn-primary w-full text-center mb-3 block">
              Call {BRAND.phoneFormatted}
            </a>
            <a href="/contact" class="btn-outline w-full text-center block">
              Request a Callback
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-primary text-primary-foreground">
    <div class="container-wide px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">
        Need {service.name} in {location.name}?
      </h2>
      <p class="text-xl text-primary-foreground/90 mb-8">
        Our local team is ready to help. Call now for fast, professional service.
      </p>
      <a href={`tel:${BRAND.phone}`} class="bg-white text-primary font-semibold px-8 py-4 rounded-lg shadow-lg hover:bg-white/90 transition-all text-lg inline-block">
        Call {BRAND.phoneFormatted}
      </a>
    </div>
  </section>
</BaseLayout>
